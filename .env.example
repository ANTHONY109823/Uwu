# Backend NestJS (futuro — no necesario para el sitio estático actual)
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=4000
CORS_ORIGINS="http://localhost:3000"
NODE_ENV=development

# Mercado Pago (opcional)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_PUBLIC_KEY=""

# Frontend Next.js
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Admin seed NestJS (solo primera ejecución)
ADMIN_EMAIL="admin@uwu.app"
ADMIN_PASSWORD="uwu-admin-2026"

# ═══════════════════════════════════════════════════════════════
# RAILWAY — sitio estático + API sync (deploy actual)
# Valores reales en `.env.railway` (local, gitignored)
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
STORAGE_ROOT=/data
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esto-por-una-contraseña-larga
ADMIN_TOKEN=genera-con-openssl-rand-hex-32
# PORT → Railway lo asigna automáticamente
# Volumen: mount /data en la pestaña Volumes
