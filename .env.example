# Backend — SQLite local (sin Docker). Para producción Railway usa PostgreSQL:
# DATABASE_URL="postgresql://user:pass@host:5432/uwu"
DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production-use-long-random-string"
PORT=4000
CORS_ORIGINS="http://localhost:3000"
NODE_ENV=development

# Mercado Pago (opcional — sin esto los pagos se simulan)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_PUBLIC_KEY=""

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Railway — sitio estático + sync admin (no requiere PostgreSQL)
ADMIN_TOKEN="genera-un-token-largo-y-secreto"
STORAGE_ROOT="/data"
PORT=3000

# Admin seed (solo primera ejecución)
ADMIN_EMAIL="admin@uwu.app"
ADMIN_PASSWORD="uwu-admin-2026"
