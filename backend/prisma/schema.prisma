generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum TierLevel {
  free
  premium
  exclusive
}

enum OrderStatus {
  draft
  pending
  paid
  free
  failed
  expired
  refunded
}

enum PaymentStatus {
  pending
  approved
  rejected
  cancelled
  refunded
}

enum AdminRole {
  superadmin
  editor
  support
  analyst
}

enum MusicSource {
  text
  youtube
  spotify
  upload
}

model Category {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  name        String
  emoji       String     @default("❤️")
  description String?
  sortOrder   Int        @default(0) @map("sort_order")
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  templates   Template[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Level {
  id        Int        @id @default(autoincrement())
  code      TierLevel  @unique
  name      String
  emoji     String
  pricePen  Float      @default(0) @map("price_pen")
  priceUsd  Float      @default(0) @map("price_usd")
  features  Json       @default("[]")
  createdAt DateTime   @default(now()) @map("created_at")
  templates Template[]

  @@map("levels")
}

model Template {
  id               Int             @id @default(autoincrement())
  slug             String          @unique
  code             String          @unique
  name             String
  emoji            String
  description      String?
  categoryId       Int             @map("category_id")
  levelId          Int             @map("level_id")
  pricePen         Float?          @map("price_pen")
  priceUsd         Float?          @map("price_usd")
  previewGradient  String?         @map("preview_gradient")
  pillText         String?         @map("pill_text")
  titleText        String?         @map("title_text")
  htmlPath         String?         @map("html_path")
  configJson       Json?           @map("config_json")
  isActive         Boolean         @default(true) @map("is_active")
  isFeatured       Boolean         @default(false) @map("is_featured")
  sortOrder        Int             @default(0) @map("sort_order")
  visitCount       Int             @default(0) @map("visit_count")
  purchaseCount    Int             @default(0) @map("purchase_count")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  category         Category        @relation(fields: [categoryId], references: [id])
  level            Level           @relation(fields: [levelId], references: [id])
  fields           TemplateField[]
  orders           Order[]
  dedications      Dedication[]

  @@index([categoryId])
  @@index([levelId])
  @@index([isActive, sortOrder])
  @@map("templates")
}

model TemplateField {
  id          Int      @id @default(autoincrement())
  templateId  Int      @map("template_id")
  fieldKey    String   @map("field_key")
  fieldType   String   @map("field_type")
  label       String
  placeholder String?
  maxLength   Int?     @map("max_length")
  isRequired  Boolean  @default(true) @map("is_required")
  sortOrder   Int      @default(0) @map("sort_order")
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, fieldKey])
  @@map("template_fields")
}

model Order {
  id         String      @id @default(uuid())
  templateId Int         @map("template_id")
  status     OrderStatus @default(draft)
  currency   String      @default("PEN")
  amount     Float       @default(0)
  draftData  Json?       @map("draft_data")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  expiresAt  DateTime?   @map("expires_at")
  template   Template    @relation(fields: [templateId], references: [id])
  payment    Payment?
  dedication Dedication?

  @@index([status])
  @@index([templateId])
  @@map("orders")
}

model Payment {
  id             String        @id @default(uuid())
  orderId        String        @unique @map("order_id")
  mercadopagoId  String?       @unique @map("mercadopago_id")
  preferenceId   String?       @map("preference_id")
  status         PaymentStatus @default(pending)
  currency       String        @default("PEN")
  amount         Float         @default(0)
  paymentMethod  String?       @map("payment_method")
  mpRawResponse  Json?         @map("mp_raw_response")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  order          Order         @relation(fields: [orderId], references: [id])

  @@index([status])
  @@map("payments")
}

model WebhookEvent {
  id             String   @id @default(uuid())
  notificationId String   @unique @map("notification_id")
  source         String   @default("mercadopago")
  payload        Json
  processed      Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("webhook_events")
}

model Dedication {
  id          String             @id @default(uuid())
  orderId     String?            @unique @map("order_id")
  templateId  Int                @map("template_id")
  slug        String             @unique
  accessCode  String             @unique @map("access_code")
  para        String
  de          String
  mensaje     String
  cancion     String?
  musicSource MusicSource        @default(text) @map("music_source")
  musicUrl    String?            @map("music_url")
  htmlContent String?            @map("html_content")
  isActive    Boolean            @default(true) @map("is_active")
  expiresAt   DateTime?          @map("expires_at")
  editUntil   DateTime?          @map("edit_until")
  visitCount  Int                @default(0) @map("visit_count")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  order       Order?             @relation(fields: [orderId], references: [id])
  template    Template           @relation(fields: [templateId], references: [id])
  images      DedicationImage[]
  music       DedicationMusic?
  visits      Visit[]

  @@index([templateId])
  @@index([isActive])
  @@map("dedications")
}

model DedicationImage {
  id           String     @id @default(uuid())
  dedicationId String     @map("dedication_id")
  url          String
  storageKey   String     @map("storage_key")
  mimeType     String     @map("mime_type")
  sizeBytes    Int        @map("size_bytes")
  sortOrder    Int        @default(0) @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")
  dedication   Dedication @relation(fields: [dedicationId], references: [id], onDelete: Cascade)

  @@index([dedicationId])
  @@map("dedication_images")
}

model DedicationMusic {
  id           String      @id @default(uuid())
  dedicationId String      @unique @map("dedication_id")
  source       MusicSource
  title        String?
  url          String?
  fileKey      String?     @map("file_key")
  createdAt    DateTime    @default(now()) @map("created_at")
  dedication   Dedication  @relation(fields: [dedicationId], references: [id], onDelete: Cascade)

  @@map("dedication_music")
}

model Visit {
  id           BigInt     @id @default(autoincrement())
  dedicationId String     @map("dedication_id")
  ipHash       String?    @map("ip_hash")
  userAgent    String?    @map("user_agent")
  referrer     String?
  createdAt    DateTime   @default(now()) @map("created_at")
  dedication   Dedication @relation(fields: [dedicationId], references: [id])

  @@index([dedicationId])
  @@index([createdAt(sort: Desc)])
  @@map("visits")
}

model AdminUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  role         AdminRole  @default(editor)
  isActive     Boolean    @default(true) @map("is_active")
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  auditLogs    AuditLog[]

  @@map("admin_users")
}

model AuditLog {
  id         BigInt     @id @default(autoincrement())
  adminId    String?    @map("admin_id")
  action     String
  entityType String?    @map("entity_type")
  entityId   String?    @map("entity_id")
  details    Json?
  createdAt  DateTime   @default(now()) @map("created_at")
  admin      AdminUser? @relation(fields: [adminId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model Setting {
  key         String   @id
  value       Json
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
